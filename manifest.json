{
  "manifest_version": 3,
  "name": "VibePaste",
  "version": "0.1.0",
  "description": "Capture UI elements for AI coding prompts.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_title": "VibePaste"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "commands": {
    "toggle-selection": {
      "suggested_key": {
        "default": "Alt+C"
      },
      "description": "Toggle Element Selection"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content/styles.css"],
      "js": [
        "shared/constants.js", 
        "core/extractor.js", 
        "core/compiler.js",
        "core/action.js",
        "content/ui.js",
        "content/voice.js",
        "content/selection.js"
      ]
    }
  ]
}