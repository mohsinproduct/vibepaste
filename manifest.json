{
  "manifest_version": 3,
  "name": "VibePaste",
  "version": "0.1.0",
  "description": "Capture UI elements for AI coding prompts.",
  "permissions": [
    "activeTab", 
    "storage", 
    "scripting",
    "unlimitedStorage"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "VibePaste"
  },

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "commands": {
    "capture-vibe": {
      "suggested_key": { "default": "Alt+C" },
      "description": "Start/Stop Capturing"
    },
    "vibe-paste": {
      "suggested_key": { "default": "Alt+V" },
      "description": "Paste Captured Vibe"
    },
    "pause-vibe": {
      "suggested_key": { "default": "Alt+P" },
      "description": "Pause/Unpause Capturing"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content/styles.css"],
      "js": [
        "shared/constants.js", 
        "core/extractor.js", 
        "core/compiler.js",
        "core/action.js",
        "content/ui.js",
        "content/voice.js",
        "content/selection.js",
        "content/injector.js"
      ]
    }
  ]
}